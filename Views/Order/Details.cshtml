@model Order

@{
    ViewData["Title"] = "Order Details";

    string StatusLabel(int s) => s switch
    {
        0 => "Pending",
        1 => "Processing",
        2 => "Shipped",
        3 => "Delivered",
        4 => "Cancelled",
        _ => "Unknown"
    };

    string StatusClass(int s) => s switch
    {
        0 => "bg-warning-subtle text-warning-emphasis",
        1 => "bg-info-subtle text-info-emphasis",
        2 => "bg-primary-subtle text-primary-emphasis",
        3 => "bg-success-subtle text-success-emphasis",
        4 => "bg-danger-subtle text-danger-emphasis",
        _ => "bg-secondary-subtle text-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Order Details</h1>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.OrderId" class="btn btn-outline-warning btn-sm">Update Status</a>
            <a asp-controller="Admin" asp-action="Orders" class="btn btn-outline-secondary btn-sm">All Orders</a>
        }
        else
        {
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">My Orders</a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card form-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <div class="small text-muted">Order Number</div>
                    <div class="font-monospace">@Model.OrderNum</div>
                </div>
                <span class="badge rounded-pill @StatusClass(Model.Status)">@StatusLabel(Model.Status)</span>
            </div>
            <div class="small text-muted mb-3">Placed on @Model.OrderDate.ToString("MMMM dd, yyyy HH:mm")</div>

            <h2 class="h6 mb-3">Items</h2>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Unit Price</th>
                            <th>Qty</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@(item.Product?.Name ?? $"Product #{item.ProductId}")</td>
                                <td>@item.UnitPrice.ToString("C")</td>
                                <td>@item.Quantity</td>
                                <td class="text-end">@item.LineTotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-group-divider">
                        <tr>
                            <td colspan="3" class="text-end fw-semibold">Order Total</td>
                            <td class="text-end fw-bold text-primary">@Model.TotalAmount.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        @if (Model.ShippingAddress != null)
        {
            <div class="card form-card p-4 mb-3">
                <h2 class="h6 mb-3">Shipping Address</h2>
                <p class="mb-0">
                    @Model.ShippingAddress.Street<br />
                    @Model.ShippingAddress.City, @Model.ShippingAddress.Country<br />
                    <span class="text-muted">@Model.ShippingAddress.Zip</span>
                </p>
            </div>
        }

        @if (User.IsInRole("Admin") && Model.User != null)
        {
            <div class="card form-card p-4">
                <h2 class="h6 mb-3">Customer</h2>
                <p class="mb-1 fw-semibold">@Model.User.FullName</p>
                <p class="mb-0 text-muted small">@Model.User.Email</p>
            </div>
        }
    </div>
</div>