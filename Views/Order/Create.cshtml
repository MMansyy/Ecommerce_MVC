@model CheckOutVM

@{
    ViewData["Title"] = "Checkout";
    bool hasAddresses = Model.Addresses.Any();
    string addAddressUrl = Url.Action("Create", "Address", new { returnUrl = Url.Action("Create", "Order") })!;
}

<h1 class="h3 mb-4">Checkout</h1>

<form asp-action="Create" asp-controller="Order" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card form-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Shipping Address</h2>
                    <a href="@addAddressUrl" class="btn btn-outline-primary btn-sm">+ Add Address</a>
                </div>

                @if (hasAddresses)
                {
                    @foreach (var address in Model.Addresses)
                    {
                        <div class="form-check mb-2 p-3 border rounded-3 @(address.IsDefault ? "border-primary" : "")">
                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="AddressId"
                                   value="@address.AddressId"
                                   id="addr_@address.AddressId" />
                            <label class="form-check-label ms-2 w-100" for="addr_@address.AddressId">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong>@address.Street</strong><br />
                                        <span class="text-muted">@address.City, @address.Country @address.Zip</span>
                                    </div>
                                    @if (address.IsDefault)
                                    {
                                        <span class="badge bg-primary ms-2">Default</span>
                                    }
                                </div>
                            </label>
                        </div>
                    }
                    <span asp-validation-for="AddressId" class="text-danger small"></span>
                }
                else
                {
                    <div class="text-center py-4">
                        <p class="text-muted mb-3">You don't have a shipping address yet.</p>
                        <a href="@addAddressUrl" class="btn btn-primary">
                            Add Shipping Address
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card form-card p-4">
                <h2 class="h5 mb-3">Order Summary</h2>
                <div class="table-responsive mb-3">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CartItems)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td class="text-end">@item.Quantity</td>
                                    <td class="text-end">@item.Total.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <hr />
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Subtotal</span>
                    <span>@Model.SubTotal.ToString("C")</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Shipping</span>
                    <span>@Model.ShippingCost.ToString("C")</span>
                </div>
                <div class="d-flex justify-content-between mb-4 fw-bold fs-5">
                    <span>Total</span>
                    <span class="text-primary">@Model.Total.ToString("C")</span>
                </div>

                <button type="submit" class="btn btn-primary w-100 @(!hasAddresses ? "disabled" : "")"
                        @(!hasAddresses ? "aria-disabled=true" : "")>
                    Place Order
                </button>
                @if (!hasAddresses)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">You need an address before placing an order.</small>
                    </div>
                }
                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Back to Cart</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}