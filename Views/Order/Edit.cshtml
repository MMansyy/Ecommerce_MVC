@model Order

@{
    ViewData["Title"] = "Update Order Status";

    string StatusLabel(int s) => s switch
    {
        0 => "Pending",
        1 => "Processing",
        2 => "Shipped",
        3 => "Delivered",
        4 => "Cancelled",
        _ => "Unknown"
    };
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card form-card p-4 p-md-5">
            <h1 class="h4 mb-4">Update Order Status</h1>

            <dl class="row mb-4">
                <dt class="col-sm-4">Order #</dt>
                <dd class="col-sm-8 font-monospace">@Model.OrderNum</dd>

                <dt class="col-sm-4">Customer</dt>
                <dd class="col-sm-8">@(Model.User?.FullName ?? Model.UserId)</dd>

                <dt class="col-sm-4">Total</dt>
                <dd class="col-sm-8 fw-semibold text-primary">@Model.TotalAmount.ToString("C")</dd>

                <dt class="col-sm-4">Current Status</dt>
                <dd class="col-sm-8">@StatusLabel(Model.Status)</dd>
            </dl>

            <form asp-action="Edit" asp-controller="Order" asp-route-id="@Model.OrderId" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label for="orderStatus" class="form-label fw-semibold">New Status</label>
                    <select id="orderStatus" name="orderStatus" class="form-select">
                        @{
                            var statuses = new Dictionary<int, string>
                            {
                                { 0, "Pending" }, { 1, "Processing" }, { 2, "Shipped" },
                                { 3, "Delivered" }, { 4, "Cancelled" }
                            };
                        }
                        @foreach (var s in statuses)
                        {
                            if (s.Key == Model.Status)
                            {
                                <option value="@s.Key" selected>@s.Value</option>
                            }
                            else
                            {
                                <option value="@s.Key">@s.Value</option>
                            }
                        }
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>