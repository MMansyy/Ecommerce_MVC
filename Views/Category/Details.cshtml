@model Category

@{
    ViewData["Title"] = "Category Details";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card form-card p-4 p-md-5">
            <h1 class="h4 mb-4">Category Details</h1>

            <dl class="row mb-4">
                <dt class="col-sm-4">Category ID</dt>
                <dd class="col-sm-8">@Model.CategoryId</dd>

                <dt class="col-sm-4">Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4">Parent Category ID</dt>
                <dd class="col-sm-8">@(Model.ParentCategoryId?.ToString() ?? "-")</dd>
            </dl>

            <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn btn-primary">Edit</a>
            <a asp-action="Index" asp-controller="Category" class="btn btn-outline-secondary ms-2">Back</a>
        </div>
    </div>
</div>