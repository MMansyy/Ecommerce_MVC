@model Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card form-card p-4 p-md-5">
            <h1 class="h4 text-danger mb-3">Delete Category</h1>
            <p class="text-muted">Are you sure you want to delete this category?</p>

            <dl class="row mb-4">
                <dt class="col-sm-5">Name</dt>
                <dd class="col-sm-7">@Model.Name</dd>

                <dt class="col-sm-5">Parent Category ID</dt>
                <dd class="col-sm-7">@(Model.ParentCategoryId?.ToString() ?? "-")</dd>
            </dl>

            <form asp-action="Delete" asp-controller="Category" method="post">
                <input type="hidden" name="id" value="@Model.CategoryId" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" asp-controller="Category" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>