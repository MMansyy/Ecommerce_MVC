@model Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card form-card p-4 p-md-5">
            <h1 class="h4 mb-4">Edit Category</h1>

            <form asp-action="Edit" asp-controller="Category" method="post" novalidate>
                <input asp-for="CategoryId" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ParentCategoryId" class="form-label"></label>
                    <input asp-for="ParentCategoryId" class="form-control" />
                    <span asp-validation-for="ParentCategoryId" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" asp-controller="Category" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}