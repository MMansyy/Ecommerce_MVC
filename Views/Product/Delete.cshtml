@model Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card form-card p-4 p-md-5">
            <h1 class="h4 text-danger mb-3">Delete Product</h1>
            <p class="text-muted">Are you sure you want to delete this product?</p>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }
            

            <dl class="row mb-4">
                <dt class="col-sm-4">Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4">Category</dt>
                <dd class="col-sm-8">@(Model.Category?.Name ?? "-")</dd>

                <dt class="col-sm-4">Price</dt>
                <dd class="col-sm-8">@Model.Price.ToString("C")</dd>

                <dt class="col-sm-4">Stock</dt>
                <dd class="col-sm-8">@Model.StockQuantity</dd>
            </dl>

            <form asp-action="Delete" asp-controller="Product" method="post">
                <input type="hidden" name="id" value="@Model.ProductId" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" asp-controller="Product" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>