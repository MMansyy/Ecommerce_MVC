@model AdminDashboardVM

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Admin Dashboard</h1>
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary btn-sm">View Store</a>
</div>

<div class="card form-card p-3 mb-4">
    <h2 class="h5 mb-3">Management</h2>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-sm">Manage Products</a>
        <a asp-controller="Category" asp-action="Index" class="btn btn-success btn-sm">Manage Categories</a>
        <a asp-controller="Admin" asp-action="Orders" class="btn btn-warning btn-sm">Manage Orders</a>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-5 g-3 mb-4">
    <div class="col"><div class="card panel-card p-3"><div class="small text-muted">Products</div><div class="h4 mb-0">@Model.TotalProducts</div></div></div>
    <div class="col"><div class="card panel-card p-3"><div class="small text-muted">Categories</div><div class="h4 mb-0">@Model.TotalCategories</div></div></div>
    <div class="col"><div class="card panel-card p-3"><div class="small text-muted">Orders</div><div class="h4 mb-0">@Model.TotalOrders</div></div></div>
    <div class="col"><div class="card panel-card p-3"><div class="small text-muted">Customers</div><div class="h4 mb-0">@Model.TotalCustomers</div></div></div>
    <div class="col"><div class="card panel-card p-3"><div class="small text-muted">Revenue</div><div class="h4 mb-0">@Model.TotalRevenue.ToString("C")</div></div></div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card form-card p-3">
            <h2 class="h5 mb-3">Recent Orders</h2>
            @if (Model.RecentOrders.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Order #</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td class="font-monospace small">@order.OrderNum[..8]…</td>
                                    <td>@(order.User?.FullName ?? order.UserId)</td>
                                    <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                    <td>@order.TotalAmount.ToString("C")</td>
                                    <td>
                                        @{
                                            var (label, cls) = order.Status switch
                                            {
                                                0 => ("Pending", "bg-warning-subtle text-warning-emphasis"),
                                                1 => ("Processing", "bg-info-subtle text-info-emphasis"),
                                                2 => ("Shipped", "bg-primary-subtle text-primary-emphasis"),
                                                3 => ("Delivered", "bg-success-subtle text-success-emphasis"),
                                                4 => ("Cancelled", "bg-danger-subtle text-danger-emphasis"),
                                                _ => ("Unknown", "bg-secondary-subtle text-secondary")
                                            };
                                        }
                                        <span class="badge rounded-pill @cls">@label</span>
                                    </td>
                                    <td>
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-outline-secondary btn-sm">View</a>
                                        <a asp-controller="Order" asp-action="Edit" asp-route-id="@order.OrderId" class="btn btn-outline-warning btn-sm">Status</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-muted">No orders yet.</div>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card form-card p-3">
            <h2 class="h5 mb-3">Low Stock Products</h2>
            @if (Model.LowStockProducts.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var product in Model.LowStockProducts)
                    {
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-semibold">@product.Name</div>
                                <small class="text-muted">@(product.Category?.Name ?? "General")</small>
                            </div>
                            <span class="badge bg-warning-subtle text-warning-emphasis">@product.StockQuantity left</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-muted">Stock levels are healthy.</div>
            }
        </div>
    </div>
</div></div>