@model List<Order>

@{
    ViewData["Title"] = "Manage Orders";

    string StatusLabel(int s) => s switch
    {
        0 => "Pending",
        1 => "Processing",
        2 => "Shipped",
        3 => "Delivered",
        4 => "Cancelled",
        _ => "Unknown"
    };

    string StatusClass(int s) => s switch
    {
        0 => "bg-warning-subtle text-warning-emphasis",
        1 => "bg-info-subtle text-info-emphasis",
        2 => "bg-primary-subtle text-primary-emphasis",
        3 => "bg-success-subtle text-success-emphasis",
        4 => "bg-danger-subtle text-danger-emphasis",
        _ => "bg-secondary-subtle text-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Manage Orders</h1>
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">Dashboard</a>
</div>

<div class="card form-card p-3">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="font-monospace small">@order.OrderNum[..8]…</td>
                            <td>@(order.User?.FullName ?? order.UserId)</td>
                            <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>@order.OrderItems.Count</td>
                            <td class="fw-semibold">@order.TotalAmount.ToString("C")</td>
                            <td>
                                <span class="badge rounded-pill @StatusClass(order.Status)">@StatusLabel(order.Status)</span>
                            </td>
                            <td class="text-end">
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-outline-secondary btn-sm">View</a>
                                <a asp-controller="Order" asp-action="Edit" asp-route-id="@order.OrderId" class="btn btn-outline-warning btn-sm">Status</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-muted p-3">No orders placed yet.</div>
    }
</div>