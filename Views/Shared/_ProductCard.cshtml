@model Product

<div class="col">
    <div class="card h-100 border-0 shadow-sm product-card">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="product-image border-bottom" />
        }
        else
        {
            <div class="product-image d-flex align-items-center justify-content-center bg-light border-bottom">
                <div class="text-center px-3">
                    <div class="fw-semibold">@Model.Name</div>
                    <div class="small text-muted">SKU: @Model.SKU</div>
                </div>
            </div>
        }
        <div class="card-body d-flex flex-column">
            <div class="small text-muted mb-1">@(Model.Category?.Name ?? "General")</div>
            <h5 class="card-title text-truncate">@Model.Name</h5>
            <p class="card-text text-muted small mb-3">@(string.IsNullOrWhiteSpace(Model.Description) ? "No description available." : Model.Description)</p>
            <div class="mt-auto d-flex justify-content-between align-items-center">
                <span class="fw-bold text-primary fs-5">@Model.Price.ToString("C")</span>
                <div class="d-flex gap-2">
                    <a asp-controller="Catalog" asp-action="Details" asp-route-id="@Model.ProductId" class="btn btn-outline-secondary btn-sm">Details</a>
                    <a asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.ProductId" class="btn btn-primary btn-sm">Add to cart</a>
                </div>
            </div>
        </div>
    </div>
</div>