@model HomeVM

@{
    ViewData["Title"] = "Home";
}

<section class="hero p-4 p-md-5 mb-4 shadow-sm">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="badge bg-light text-primary border mb-3">Modern eCommerce Experience</span>
            <h1 class="display-5 fw-bold mb-3">Minimal store, real data, fast shopping.</h1>
            <p class="text-muted mb-4">Discover products, filter quickly, and checkout with a clean workflow designed for performance and clarity.</p>
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary px-4">Start Shopping</a>
                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary px-4">View Cart</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h2 class="h5 mb-3">Store at a glance</h2>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Active Products</span>
                        <strong>@Model.ProductsCount</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Categories</span>
                        <strong>@Model.CategoriesCount</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 fw-semibold section-title mb-0">Browse by Category</h2>
        <a asp-controller="Catalog" asp-action="Index" class="text-decoration-none">See all products</a>
    </div>

    @if (Model.TopCategories.Any())
    {
        <div class="d-flex flex-wrap gap-2">
            @foreach (var category in Model.TopCategories)
            {
                <a asp-controller="Catalog" asp-action="Index" asp-route-CategoryId="@category.CategoryId" class="btn btn-outline-secondary rounded-pill">@category.Name</a>
            }
        </div>
    }
    else
    {
        <div class="alert alert-light border text-muted">No categories available yet.</div>
    }
</section>

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 fw-semibold section-title mb-0">Featured Products</h2>
        <a asp-controller="Catalog" asp-action="Index" class="text-decoration-none">View all</a>
    </div>

    @if (Model.FeaturedProducts.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            @foreach (var product in Model.FeaturedProducts)
            {
                @await Html.PartialAsync("_ProductCard", product)
            }
        </div>
    }
    else
    {
        <div class="alert alert-light border text-muted">No products are available yet.</div>
    }
</section>
