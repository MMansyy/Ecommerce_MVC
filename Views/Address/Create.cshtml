@model AddressVM

@{
    ViewData["Title"] = "Add Address";
    bool isCheckout = !string.IsNullOrEmpty(Model.ReturnUrl);
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card form-card p-4 p-md-5">
            @if (isCheckout)
            {
                <div class="alert alert-info mb-4 d-flex align-items-center gap-2">
                    <span>Add a shipping address to continue with your checkout.</span>
                </div>
            }

            <h1 class="h4 mb-4">Add Shipping Address</h1>

            <form asp-action="Create" asp-controller="Address" method="post" novalidate>
                <input asp-for="ReturnUrl" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Country" class="form-label"></label>
                    <input asp-for="Country" class="form-control" placeholder="e.g. Egypt" />
                    <span asp-validation-for="Country" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" placeholder="e.g. Cairo" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Street" class="form-label"></label>
                    <input asp-for="Street" class="form-control" placeholder="e.g. 15 Tahrir St, Apt 3" />
                    <span asp-validation-for="Street" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Zip" class="form-label">Zip / Postal Code</label>
                    <input asp-for="Zip" class="form-control" placeholder="e.g. 11511" />
                    <span asp-validation-for="Zip" class="text-danger"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="IsDefault" class="form-check-input" />
                    <label asp-for="IsDefault" class="form-check-label">Set as default address</label>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">
                        @(isCheckout ? "Save & Continue to Checkout" : "Save Address")
                    </button>
                    @if (isCheckout)
                    {
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">Back to Cart</a>
                    }
                    else
                    {
                        <a asp-action="Index" asp-controller="Address" class="btn btn-outline-secondary">Cancel</a>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}